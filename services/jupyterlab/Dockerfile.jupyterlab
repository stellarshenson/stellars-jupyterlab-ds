## CUDNN_PATH/LD_LIBRARY_PATH intentionally NOT set here: the old value pointed at
## a nonexistent path (python3.1 typo, and cudnn is not in base site-packages) -
## runtime LD_LIBRARY_PATH hygiene lives in 03_cleanup_ld_library_path.sh


########################################################
#  JUPYTERLAB INSTALLATION                             #
########################################################

## update conda by installing jupyterlab
## we didn't do this earlier to have jupyterlab only in base
## and not to clone it to other environments
USER ${CONDA_USER}
RUN <<-EOF
    echo "installing Jupyterlab in ${CONDA_DEFAULT_ENV} env"
    set -e
    ${CONDA_CMD} env update --name ${CONDA_DEFAULT_ENV} --file=/environment_base_jupyterlab.yml
    cp ${CONDA_HOME}/conda-meta/history /tmp/conda-meta-history
    ${CONDA_CMD} clean -a -y
    cp /tmp/conda-meta-history ${CONDA_HOME}/conda-meta/history
    # nb_venv_kernels' installer writes kernel_spec_manager_class under both the
    # deprecated NotebookApp key (Jupyter Server logs a deprecation warning for it
    # at every launch) and the modern ServerApp key. Drop the redundant NotebookApp
    # block so only ServerApp remains - no warning, identical behaviour.
    JUPYTER_CONFIG_JSON="${JUPYTER_ETC_DIR}/jupyter_config.json"
    if [ -f "${JUPYTER_CONFIG_JSON}" ]; then
        ${CONDA_CMD} run --name ${CONDA_DEFAULT_ENV} python -c 'import json,sys,pathlib; p=pathlib.Path(sys.argv[1]); c=json.loads(p.read_text()); c.pop("NotebookApp",None); p.write_text(json.dumps(c,indent=2)+"\n")' "${JUPYTER_CONFIG_JSON}"
    fi
EOF

## change persmissions of shared resources
USER root
RUN <<-EOF
    echo "changing permissions of files in the shared folder app extension"
    set -e
    find ${JUPYTER_SHARE_PATH}/jupyter_app_launcher -type f -exec chmod a-x {} +
EOF

## install the duoptimum-lab-utils wheel (built in the builder stage) into the
## base env, then drop the wheel so it is not retained in the final image. The
## console script lands in ${CONDA_HOME}/bin, which is on PATH only while base is
## active; symlink it into /opt/utils - which start-platform prepends to PATH in
## every conda env - so `lab-utils` is the env-independent overlay to the base
## install (works after `conda activate <other-env>`).
COPY --from=builder /opt/duoptimum-wheel /tmp/duoptimum-wheel
RUN <<-EOF
    echo "installing duoptimum-lab-utils into base"
    set -e
    conda run -n base pip install --no-deps --no-index --no-cache-dir \
        --find-links /tmp/duoptimum-wheel duoptimum-lab-utils
    # the conda tree belongs to ${CONDA_USER} - root-owned package files inside it
    # would make the user's own pip upgrade/uninstall of the package fail
    chown -R ${CONDA_USER}:${CONDA_USER_GROUP} \
        ${CONDA_HOME}/lib/python*/site-packages/duoptimum_lab_utils \
        ${CONDA_HOME}/lib/python*/site-packages/duoptimum_lab_utils-* \
        ${CONDA_HOME}/bin/lab-utils*
    ln -sf ${CONDA_HOME}/bin/lab-utils /opt/utils/lab-utils
    ln -sf ${CONDA_HOME}/bin/lab-utils-env /opt/utils/lab-utils-env
    ln -sf ${CONDA_HOME}/bin/lab-utils-onstart /opt/utils/lab-utils-onstart
    # quick commands advertised in the workspace README - reachable without the menu
    ln -sf /opt/utils/lab-utils.d/new-project.sh /opt/utils/new-project.sh
    ln -sf /opt/utils/lab-utils.d/test-cuda.sh /opt/utils/test-cuda.sh
    rm -rf /tmp/duoptimum-wheel
EOF

########################################################
#  PLAYWRIGHT CHROMIUM (system-wide)                   #
########################################################
# Required by:
#   - jupyterlab_export_markdown_extension: rasterises SVGs for DOCX/PDF export
#   - Playwright MCP server: lets AI assistants drive a browser
#   - Agentic AI: lets agents operate user webapps (Streamlit, Shiny, Gradio,
#     Chainlit, MLFlow) running behind the JupyterLab proxy
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright
RUN <<-EOF
    echo "installing Playwright Chromium system-wide to ${PLAYWRIGHT_BROWSERS_PATH}"
    set -e
    mkdir -p ${PLAYWRIGHT_BROWSERS_PATH}
    ${CONDA_CMD} run --name ${CONDA_DEFAULT_ENV} \
        playwright install --with-deps chromium
    # readable for all; group-writable for the jupyter group so users can
    # install extra browsers at runtime; setgid dirs keep new files in-group
    chgrp -R ${JUPYTER_GROUP} ${PLAYWRIGHT_BROWSERS_PATH}
    chmod -R a+rX,g+w ${PLAYWRIGHT_BROWSERS_PATH}
    find ${PLAYWRIGHT_BROWSERS_PATH} -type d -exec chmod g+s {} +
EOF

########################################################
#  PULSEAUDIO + SOX VOICE STACK (Claude Code /voice)   #
########################################################
# Routes the browser mic (via the jupyterlab voice-capture extension's FIFO at
# /run/voice/pulseaudio.fifo) into PulseAudio's default source so SoX `rec` -
# and thus Claude Code /voice - can record. The installer ships in the stellars
# jupyterlab bundle; see Dockerfile.jupyterlab.target.d/README.md. Packages +
# /etc/pulse/client.conf + AUDIODRIVER + the lab-owned /run/voice dir are baked
# here (/run is plain writable-layer in docker, not tmpfs, so the dir and its
# ownership persist); the daemon is started at boot by
# start-platform.d/15_start_pulseaudio.sh - no sudo needed.
COPY --chmod=755 ./Dockerfile.jupyterlab.target.d/ /opt/target-install/
RUN <<-EOF
    echo "installing pulseaudio voice stack and removing the installer"
    set -e
    /opt/target-install/install-pulseaudio.sh
    chown ${CONDA_USER}:${JUPYTER_GROUP} /run/voice
    rm -rf /opt/target-install
EOF

########################################################
#  GENERATIVE AI WITHi CUDA SUPPORT ON TORCH           #
########################################################

## packages were built by the builder container, install them all
## among the packages is CUDA supported llama-cpp-python
## other environments will inherit this when cloned from base
#USER ${CONDA_USER}
#RUN <<-EOF
#    echo "installing packages built with builder: `ls ${EXPORT_DIR}/*.whl`"
#    conda run -n ${CONDA_TORCH_ENV} pip install ${EXPORT_DIR}/*.whl
#EOF

########################################################
#  FINAL UPDATE AND CLEANUP                            #
########################################################

## final round of updates to keep all up to date and final cleanup
RUN <<-EOF
    echo "final conda cache cleanup"
    set -e
    CONDA_DEFAULT_ENV=${CONDA_DEFAULT_ENV:-base} conda clean -ltpy
    # pip http cache is disabled build-wide via PIP_NO_CACHE_DIR - nothing to purge
EOF
## COMMENTED OUT - tensorflow, torch, r_base are now installed on-demand
#RUN CONDA_DEFAULT_ENV=${CONDA_TENSORFLOW_ENV} conda clean -ltpy && pip cache purge
#RUN CONDA_DEFAULT_ENV=${CONDA_TORCH_ENV} conda clean -ltpy && pip cache purge
#RUN CONDA_DEFAULT_ENV=${CONDA_R_ENV} conda clean -ltpy && pip cache purge

## apt cleanup and remove prebuilt packages
USER root
RUN <<-EOF
    echo "apt cleanup, apt lists and the lab user's build-time pip cache"
    set -e
    apt autoremove -y
    rm -rf /var/lib/apt/lists/*
    # belt-and-braces: PIP_NO_CACHE_DIR keeps this empty during the build; the
    # real space saving is prevention - an rm here reclaims no earlier-layer space
    rm -rf /home/lab/.cache/pip
    # build-time patch inputs - root-owned in /tmp, the user could never delete them
    rm -rf /tmp/patches
EOF


########################################################
#  PREPARE DOCKER CONTAINER ENTRY POINT                #
########################################################

USER root

## ignore pip warnings re root access
ENV PIP_ROOT_USER_ACTION=ignore

## bake the platform version as an env so the banners and render-info.py can
## show "<version> build <NAME>" - PKG_VERSION is the build arg the wheel was
## stamped from (redeclared here: pre-FROM args are out of scope inside a stage)
ARG PKG_VERSION=0.0.0
ENV JUPYTERLAB_BUILD_VERSION=${PKG_VERSION}

## generate build name and build date
## and generate motd using template
RUN <<-EOF
    echo "generating build name and date"
    set -e
    date >/build-date.txt
    # build name: a short (4-6 char) UPPERCASE first name from the `names` corpus
    # (hundreds of options), installed transiently to /tmp so it never ships in the
    # runtime image - replaces gpw's pronounceable gibberish
    /opt/conda/bin/python -m pip install --quiet --no-cache-dir --target /tmp/nm names
    PYTHONPATH=/tmp/nm /opt/conda/bin/python -c "import names; n=next(x for x in iter(names.get_first_name,None) if 4<=len(x)<=6); print(n.upper())" >/build-name.txt
    rm -rf /tmp/nm
    cat /motd-template.txt | sed "s/@VERSION@/${JUPYTERLAB_BUILD_VERSION}/g" | sed "s/@BUILD_NAME@/$(cat /build-name.txt)/g" \
	| sed "s/@BUILD_DATE@/$(cat /build-date.txt)/g" > /etc/motd
    cat /welcome-template.html | sed "s/@VERSION@/${JUPYTERLAB_BUILD_VERSION}/g" | sed "s/@BUILD_NAME@/$(cat /build-name.txt)/g" \
	| sed "s/@BUILD_DATE@/$(cat /build-date.txt)/g" > /welcome.html
    rm /motd-template.txt
    rm /welcome-template.html
    # world-writable so 08_apply_system_name.sh can rebrand them without sudo
    chmod 666 /welcome.html /welcome-message.txt /etc/motd
EOF

## update terminal and shell settings
ENV TERM=xterm-256color

## default ENV parameters for jupyterlab
ENV JUPYTERLAB_SERVER_IP="*"
ENV JUPYTERLAB_SERVER_TOKEN=""
ENV JUPYTERLAB_BASE_URL="/"
ENV JUPYTERLAB_TIMEZONE=""
ENV JUPYTERLAB_SYSTEM_NAME=""
ENV JUPYTERLAB_SUDO_ENABLE=1
# 1 = user env store (~/.local/environment.env) editable and injected at start;
# 0 = locked: Settings writers hidden/refused, store not injected. Baked so
# hub-spawned containers (no compose.yml) get the default; compose passes the knob
ENV JUPYTERLAB_USER_ENV_ENABLE=1
ENV JUPYTERLAB_EXTENSIONS_MANAGER_READONLY=0

## default values for GPU support envs
# ENABLE_GPU_SUPPORT controls nvidia support of the system
# and ENABLE_GPUSTAT enables gpu status message in terminal if GPU present
ENV ENABLE_GPU_SUPPORT=0 
ENV ENABLE_GPUSTAT=1
ENV ENABLE_SERVICE_MLFLOW=1
ENV ENABLE_SERVICE_RESOURCES_MONITOR=1
ENV ENABLE_SERVICE_TENSORBOARD=1
ENV ENABLE_SERVICE_PULSEAUDIO=1
ENV ENABLE_LOCAL_SCRIPTS=1
ENV TF_CPP_MIN_LOG_LEVEL=3
ENV TENSORBOARD_LOGDIR=/tmp/tensorboard
ENV MLFLOW_DATA=${CONDA_USER_CACHE}/mlflow
# MLFLOW_TRACKING_URI is deliberately NOT baked: start-platform.sh derives it
# from the port knobs at start, so a hub/compose MLFLOW_PORT override propagates
ENV MLFLOW_PORT=5000
# loopback: mlflow has no auth - reachable only via the authenticated jupyter proxy
ENV MLFLOW_HOST=127.0.0.1
ENV MLFLOW_WORKERS=1
ENV UV_LINK_MODE=copy

# local directory with user's own start scripts
ENV LOCAL_SCRIPTS_DIR=${CONDA_USER_HOME}/.local/start-platform.d
# auxiliary paths for admin-provisioned content from shared volumes
ENV JUPYTERLAB_AUX_SCRIPTS_PATH=/mnt/shared/start-platform.d
ENV JUPYTERLAB_AUX_MENU_PATH=/mnt/shared/lab-utils.d

## setup entry point, workdir and startup command
## and set user to be conda user
USER ${CONDA_USER}
WORKDIR ${CONDA_USER_WORKSPACE}
ENTRYPOINT ["/conda-entry.sh"]
CMD ["/start-platform.sh"]

## expose ports (documentation metadata - the services behind them are proxied
## through jupyter-server-proxy under the lab host, not published individually)
# 8888 - jupyterlab, 8000 - chainlit, 8001 - jupyterhub
# 6006 - tensorboard, 5000 - mlflow, 8080 - optuna, 7681 - resources monitor (ttyd/btop)
# 8030/3030 - general purpose callback ports (typically socat-forwarded into the container)
EXPOSE 8888
EXPOSE 8000
EXPOSE 8001
EXPOSE 8080
EXPOSE 8030
EXPOSE 6006
EXPOSE 5000
EXPOSE 3030
EXPOSE 7681

# Set default terminal shell for JupyterLab
ENV JUPYTERLAB_TERMINAL_SHELL=${DEFAULT_SHELL}

# EOF

