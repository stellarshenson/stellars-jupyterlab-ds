#!/opt/conda/bin/python3
"""
Set a user environment variable in the central store ~/.local/environment.env.

Usage: set-profile-var VAR_NAME value

Historically this wrote `export VAR=...` into ~/.profile; it now routes through
the same store as the Environment Variables applet (lab-utils-env), so there is
ONE place a value lives. ~/.profile sources the store with `set -a` AFTER its
own defaults, so store values override the shipped .profile defaults and reach
the JupyterLab server, kernels, bash and fish alike.
"""

import sys

from duoptimum_lab_utils.envman import (ENV_FILE, LOCKED_MESSAGE, _NAME_RE,
                                        is_protected, set_var, store_locked)

# Colors
GREEN = '\033[0;32m'
ORANGE = '\033[0;33m'
NC = '\033[0m'


def main():
    # deployment lock: same refusal as the Environment Variables applet - the
    # menu hides the callers, this guards direct CLI invocation
    if store_locked():
        print(LOCKED_MESSAGE, file=sys.stderr)
        sys.exit(1)

    if len(sys.argv) < 3:
        print("Usage: set-profile-var VAR_NAME value", file=sys.stderr)
        sys.exit(1)

    var_name = sys.argv[1]
    value = sys.argv[2]

    # same validation as the Environment Variables applet - a malformed name would
    # land in the store as a line the applet cannot list, edit or delete
    if not _NAME_RE.match(var_name):
        print("Invalid name - letters, digits and _ only; cannot start with a digit.",
              file=sys.stderr)
        sys.exit(1)

    if is_protected(var_name):
        print(f"{var_name} is protected - overriding it can break the platform start.",
              file=sys.stderr)
        sys.exit(1)

    set_var(var_name, value)
    print(f"{GREEN}{var_name} set to: {value}{NC}")
    print(f"Store: {ENV_FILE}")
    print(f"\n{ORANGE}New terminals see the change at once - restart the server "
          f"to apply it to notebooks and services.{NC}")


if __name__ == "__main__":
    main()
