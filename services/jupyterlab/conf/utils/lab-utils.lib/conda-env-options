#!/opt/conda/bin/python3
"""
Return conda environments as JSON options for selector.

Deliberately no "current" flags: the selector's current_cmd (get-profile-var)
is the single authority for the current value - a second detection here drifted
(unanchored ~/.profile regex matched comments and ignored the env store).

Output format:
[
  {"value": "base", "label": "base"},
  {"value": "myenv", "label": "myenv"}
]
"""

import json
import os
import subprocess

# image ENV wins when set - one name, one binary (matches the shell scripts)
CONDA_CMD = os.environ.get("CONDA_CMD") or "/opt/conda/bin/conda"


def get_conda_envs() -> list:
    """Get list of conda environments."""
    try:
        result = subprocess.run(
            [CONDA_CMD, "env", "list", "--json"],
            capture_output=True,
            text=True
        )
        data = json.loads(result.stdout)
        envs = []
        for path in data.get("envs", []):
            name = os.path.basename(path)
            if path == "/opt/conda":
                name = "base"
            envs.append(name)
        return sorted(set(envs))
    except Exception:
        return []


def main():
    envs = get_conda_envs()
    print(json.dumps([{"value": e, "label": e} for e in envs]))


if __name__ == "__main__":
    main()
