#!/bin/sh
# --------------------------------------------------------------------------------------------------
#
#   Stellars JupyterLab DS Platform - linux all-in-one installer (self-extracting)
#   Project Home: https://github.com/stellarshenson/stellars-jupyterlab-ds
#
#   Extracts the embedded docker compose deployment (compose files + start/stop scripts),
#   notes the license (Elastic License 2.0, shipped as the LICENSE file), asks for the
#   initial JupyterLab password (stored in .env as JUPYTERLAB_SERVER_TOKEN),
#   writes an uninstaller and optionally starts the platform. The platform image is pulled
#   from Docker Hub on first start, nothing is built locally.
#
#   Requires docker with the compose plugin - checked before anything is installed.
#   Run as a file (sh stellars-jupyterlab-ds-setup-{version}.sh) - the payload is appended
#   below the __ARCHIVE_BELOW__ marker, so piping the script into sh will not work.
#
# --------------------------------------------------------------------------------------------------
set -e

VERSION="@VERSION@"
PROJECT_NAME="stellars-jupyterlab-ds"

echo "Stellars JupyterLab DS $VERSION - installer"
echo

# prerequisite: docker compose must be available
if ! docker compose version >/dev/null 2>&1; then
    echo "ERROR: Docker Compose was not found on this system." >&2
    echo "Install Docker Engine with the compose plugin (https://docs.docker.com/engine/install/)," >&2
    echo "Docker Desktop (https://www.docker.com/products/docker-desktop/) or" >&2
    echo "Rancher Desktop (https://rancherdesktop.io/) and run this installer again." >&2
    exit 1
fi

# license notice - full text is shipped in the payload and lands in the install directory
echo "The platform is licensed under the Elastic License 2.0 - the full text is"
echo "installed as the LICENSE file in the install directory."
echo

# platform (project) name - part of the access URL and the prefix for container and volume names
echo "The platform (project) name becomes part of the access URL (https://lab.{name}.localhost)"
echo "and the prefix for container and volume names. Lowercase letters, digits and dashes only."
while :; do
    printf "Project name [%s]: " "$PROJECT_NAME"
    read -r REPLY
    [ -z "$REPLY" ] && break
    case "$REPLY" in
        -*|*[!a-z0-9-]*) echo "Use lowercase letters, digits and dashes only (must start with a letter or digit)." ;;
        *) PROJECT_NAME="$REPLY"; break ;;
    esac
done
ACCESS_URL="https://lab.$PROJECT_NAME.localhost"
INSTALL_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/$PROJECT_NAME"

# install directory (~ is expanded manually - read does not)
printf "Install directory [%s]: " "$INSTALL_DIR"
read -r REPLY
case "$REPLY" in "~") REPLY="$HOME";; "~/"*) REPLY="$HOME${REPLY#\~}";; esac
[ -n "$REPLY" ] && INSTALL_DIR="$REPLY"
mkdir -p "$INSTALL_DIR"

# extract the embedded payload appended below the marker
ARCHIVE_LINE=$(awk '/^__ARCHIVE_BELOW__$/{print NR+1; exit}' "$0")
tail -n +"$ARCHIVE_LINE" "$0" | tar xzf - -C "$INSTALL_DIR"

# a reinstall/upgrade must never clobber the existing configuration: .env holds the
# project name (= volume prefix, losing it orphans all data) and the password
if [ -f "$INSTALL_DIR/.env" ]; then
    # the PRESERVED name wins over anything typed above; a token-only .env
    # (created by start.sh's password prompt) has no name yet - write the
    # entered one into it, otherwise compose runs under .env.default's name
    # while the printed URL advertises the entered one (last-wins on
    # duplicated keys, matching compose dotenv semantics)
    KEPT_NAME=$(grep '^COMPOSE_PROJECT_NAME=' "$INSTALL_DIR/.env" | tail -1 | cut -d= -f2 | tr -d '\r')
    echo
    if [ -n "$KEPT_NAME" ]; then
        PROJECT_NAME="$KEPT_NAME"
        echo "Existing configuration found - keeping $INSTALL_DIR/.env (project name '$PROJECT_NAME' and password preserved, entered name ignored)."
    else
        # a hand-made .env may lack the final newline - appending straight after
        # it would corrupt the last line (same guard as start.sh)
        [ -n "$(tail -c1 "$INSTALL_DIR/.env")" ] && echo >> "$INSTALL_DIR/.env"
        echo "COMPOSE_PROJECT_NAME=$PROJECT_NAME" >> "$INSTALL_DIR/.env"
        echo "Existing configuration found - keeping $INSTALL_DIR/.env (password preserved, project name '$PROJECT_NAME' applied)."
    fi
    ACCESS_URL="https://lab.$PROJECT_NAME.localhost"
    # a preserved LAB_PORT override belongs in the printed/desktop URL, exactly
    # as start.sh prints it
    KEPT_PORT=$(grep '^LAB_PORT=' "$INSTALL_DIR/.env" | tail -1 | cut -d= -f2 | tr -d '\r')
    [ -n "$KEPT_PORT" ] && [ "$KEPT_PORT" != "443" ] && ACCESS_URL="$ACCESS_URL:$KEPT_PORT"
else
    # initial password -> .env; the JupyterLab login page asks for it, it is never placed in the URL
    echo
    echo "Set the initial password for JupyterLab access."
    echo "This is the initial password; change it later in the installed .env (restart to apply)."
    trap 'stty echo 2>/dev/null || true' EXIT INT TERM # never leave the terminal with echo off (set -e aborts mid-prompt)
    JUPYTERLAB_PASSWORD=""
    while [ -z "$JUPYTERLAB_PASSWORD" ]; do
        printf "Enter a password: "
        stty -echo 2>/dev/null || true
        if ! read -r JUPYTERLAB_PASSWORD; then # stdin EOF - abort cleanly instead of dying via set -e with echo off
            stty echo 2>/dev/null || true
            echo
            echo "ERROR: no interactive input - run the installer from a terminal." >&2
            exit 1
        fi
        stty echo 2>/dev/null || true
        echo
        case "$JUPYTERLAB_PASSWORD" in *"'"*)
            echo "Single quotes (') are not supported in the password - please choose another."
            JUPYTERLAB_PASSWORD="" ;;
        esac
    done
    umask 077 # .env holds the password - never exists world-readable, even briefly
    {
        echo "# local overrides over .env.default"
        echo "# platform name - access hosts lab.{name}.localhost / traefik.{name}.localhost,"
        echo "# and the prefix for container and volume names"
        echo "COMPOSE_PROJECT_NAME=$PROJECT_NAME"
        echo "# initial JupyterLab password (login page asks for it); change it here and restart to apply"
        echo "# single-quoted so \$, # and spaces survive compose dotenv parsing verbatim"
        echo "JUPYTERLAB_SERVER_TOKEN='$JUPYTERLAB_PASSWORD'"
    } > "$INSTALL_DIR/.env"
    umask 022
fi

# uninstaller - removes containers, images, (on confirmation) data volumes, then the installed files
cat > "$INSTALL_DIR/uninstall.sh" <<'UNINSTALL_EOF'
#!/bin/sh
# Stellars JupyterLab DS Platform - uninstaller
cd "$(dirname "$0")"
# refuse to guess: without .env the project name (container/volume prefix) is unknown
# and compose would try to down a DIFFERENT (default-named) project
if [ ! -f .env ] || ! grep -q '^COMPOSE_PROJECT_NAME=' .env; then
    echo "ERROR: .env with COMPOSE_PROJECT_NAME not found - cannot tell which containers belong to this install." >&2
    echo "Restore .env (COMPOSE_PROJECT_NAME=<name>) or remove the containers manually, then re-run." >&2
    exit 1
fi
VOLUMES=""
printf "Also remove the data volumes (JupyterLab home, workspace, cache, certificates)? This permanently deletes all notebooks and data. [y/N]: "
read -r REPLY
case "$REPLY" in [Yy]*) VOLUMES="--volumes";; esac
echo "Stopping the platform and removing containers and images..."
# deletion happens ONLY after a successful down - otherwise restart:unless-stopped
# containers would resurrect with the uninstaller already gone
if ! docker compose --env-file .env.default --env-file .env -f compose.yml down --remove-orphans --rmi all $VOLUMES; then
    echo "ERROR: docker compose down failed (is docker running?) - nothing was deleted; fix docker and re-run." >&2
    exit 1
fi
INSTALL_DIR=$(pwd)
cd /
rm -f "$INSTALL_DIR/compose.yml" "$INSTALL_DIR/compose-gpu.yml" "$INSTALL_DIR/.env.default" "$INSTALL_DIR/start.sh" \
      "$INSTALL_DIR/stop.sh" "$INSTALL_DIR/LICENSE" "$INSTALL_DIR/.env" "$INSTALL_DIR/uninstall.sh"
rmdir "$INSTALL_DIR" 2>/dev/null || echo "Note: $INSTALL_DIR not empty, left in place."
echo "Uninstalled."
UNINSTALL_EOF
chmod +x "$INSTALL_DIR/uninstall.sh"

# access information
echo
echo "Installed to $INSTALL_DIR"
echo "Access URL: $ACCESS_URL"
echo "Log in with the password you set (it is not in the URL)."
echo "The password is stored in $INSTALL_DIR/.env (key JUPYTERLAB_SERVER_TOKEN)."
echo
echo "Start:     $INSTALL_DIR/start.sh"
echo "Stop:      $INSTALL_DIR/stop.sh"
echo "Uninstall: $INSTALL_DIR/uninstall.sh"
echo

# optionally start now - start.sh pulls the image when missing (several GB) and starts compose (GPU-aware)
printf "Start the platform now? [Y/n]: "
read -r REPLY
case "$REPLY" in
    [Nn]*) ;;
    *) "$INSTALL_DIR/start.sh" ;;
esac

exit 0
__ARCHIVE_BELOW__
